--- !u!114 &1276352621922922051
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 858573204869775212}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bf21a7503dfc9084a912fba9797ca7d8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  instructionPos:
  - {fileID: 858573203712590747}
  - {fileID: 858573203139649688}
  - {fileID: 858573203369111709}
  - {fileID: 858573205103519141}
  - {fileID: 858573204484480403}
  - {fileID: 858573204117817312}
  - {fileID: 858573203389785692}
  - {fileID: 858573204526669610}
  - {fileID: 858573204316726626}
  - {fileID: 858573204787567835}
  - {fileID: 858573205091617715}
  - {fileID: 874042362061446478}
  instructionText:
  - Pick up the bottom Burger Bun and place on the white surface
  - Place a beef patty on the grill to start cooking
  - Pick as many ingredients to add to burger
  - Finish the burger by placing the top Burger Bun
  - Place food on tray, it will notify if the wrong food is placed
  - Pick up the Pizza Base and place on the white surface
  - Pick as many ingredients to add to pizza
  - Place the pizza in the oven to start cooking
  - Put the food not required in the trash
  - Press the button to start coffee maker
  - Pick up the coffee cup and place on table, pour coffee till lid appears
  - When you are done familiarizing press the button below or next button to start
    experiment.
  textGO: {fileID: 7320319427064586676}
